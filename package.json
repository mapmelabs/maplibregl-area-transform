{
  "name": "maplibregl-area-transform",
  "version": "2.0.1",
  "description": "A maplibre-gl-js control to allow scaling, rotating and moving images on the map",
  "keywords": [
    "maplibre-gl-js",
    "image",
    "scale",
    "rotate",
    "transform"
  ],
  "homepage": "https://github.com/mapmelabs/maplibregl-area-transform#readme",
  "bugs": {
    "url": "https://github.com/mapmelabs/maplibregl-area-transform/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mapmelabs/maplibregl-area-transform.git"
  },
  "author": "Harel Mazor",
  "type": "commonjs",
  "main": "dist/maplibregl-area-transform.js",
  "module": "dist/maplibregl-area-transform.mjs",
  "types": "dist/maplibregl-area-transform.d.ts",
  "exports": {
    ".": {
      "import": "./dist/maplibregl-area-transform.mjs",
      "require": "./dist/maplibregl-area-transform.js",
      "types": "./dist/maplibregl-area-transform.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rolldown -c",
    "build:watch": "rolldown -c -w",
    "build-css": "mkdir -p dist && cp src/index.css dist/maplibregl-area-transform.css",
    "build-dist": "npm run build && npm run build-css",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "docs": "typedoc --out docs src/index.ts && cp -rf dist docs/ && mkdir -p docs/demo && cp test/demo.html docs/demo/index.html"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.53.1",
    "@typescript-eslint/parser": "^8.53.1",
    "@vitest/browser": "^4.1.8",
    "@vitest/browser-playwright": "^4.1.8",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "maplibre-gl": "^5.22.0",
    "playwright": "^1.60.0",
    "prettier": "^3.7.4",
    "rolldown": "^1.0.3",
    "rolldown-plugin-dts": "^0.25.2",
    "typedoc": "^0.28.18",
    "typescript": "^5.9.3",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "eventemitter3": "^5.0.4"
  }
}
